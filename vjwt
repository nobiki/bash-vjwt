#!/bin/bash

# ==========================================
# ヘルプ表示関数
# ==========================================
show_help() {
    echo -e "\e[1m名前:\e[0m"
    echo "  vjwt - CLI用のローカルJWTデコード・署名検証・エンコードツール"
    echo ""
    echo -e "\e[1m使い方:\e[0m"
    echo "  [デコードモード]"
    echo "    echo \$JWT | vjwt [オプション]"
    echo "    vjwt \$JWT [オプション]"
    echo ""
    echo "  [エンコードモード]"
    echo "    echo '{\"user_id\": 123}' | vjwt -e"
    echo "    vjwt '{\"user_id\": 123}' --encode"
    echo ""
    echo -e "\e[1mオプション:\e[0m"
    echo "  -e, --encode    エンコードモード。入力されたJSONからJWTを生成します"
    echo "  -i, --insecure  デコード時、署名検証をスキップしてペイロードのみを表示します"
    echo "  -h, --help      このヘルプを表示します"
    echo ""
    echo -e "\e[1m環境変数:\e[0m"
    echo "  VJWT_SECRET     署名・検証（HS256）に使用する秘密鍵（シークレット）[必須]"
}

# ==========================================
# 1. 最優先オプションの解析 (-h, --help)
# ==========================================
for arg in "$@"; do
    if [ "$arg" = "-h" ] || [ "$arg" = "--help" ]; then
        show_help
        exit 0
    fi
done

# ==========================================
# 2. パイプ（標準入力）または引数からデータ（JWT or JSON）を取得
# ==========================================
INPUT_ARG=""
ENCODE_MODE=false
INSECURE_MODE=false

# オプションのフラグを立てつつ、データとなる引数を特定
for arg in "$@"; do
    if [ "$arg" = "-e" ] || [ "$arg" = "--encode" ]; then
        ENCODE_MODE=true
    elif [ "$arg" = "-i" ] || [ "$arg" = "--insecure" ]; then
        INSECURE_MODE=true
    else
        INPUT_ARG="$arg"
    fi
done

if [ -t 0 ]; then
    # 端末からの実行（パイプなし）で、かつ引数も空ならヘルプを出して終了
    if [ -z "$INPUT_ARG" ]; then
        show_help
        exit 0
    fi
    INPUT_DATA="$INPUT_ARG"
else
    # パイプから取得
    INPUT_DATA=$(cat)
fi

# パイプ経由で空文字が渡された場合のガード
if [ -z "$INPUT_DATA" ]; then
    echo -e "\e[31m❌ エラー: 入力データが空です。\e[0m"
    show_help
    exit 1
fi

# ==========================================
# 3. 環境変数のチェック
# ==========================================
# 「デコードのインセキュアモード（-i）」以外は、VJWT_SECRET が必須
if [ -z "$VJWT_SECRET" ] && [ "$INSECURE_MODE" = false ]; then
    echo -e "\e[31m❌ エラー: 秘密鍵の環境変数 VJWT_SECRET が設定されていません。\e[0m"
    echo "先に環境変数を設定するか、デコード時は -i オプション（検証なし）を使用してください。"
    echo "設定例: export VJWT_SECRET=\"your_secret_key\""
    exit 1
fi

# ==========================================
# 4. モード別の処理関数
# ==========================================

# --- エンコード（生成）モード ---
do_encode() {
    # JSONのバリデーション
    if ! echo "$INPUT_DATA" | jq . >/dev/null 2>&1; then
        echo -e "\e[31m❌ エラー: 入力されたデータが正しいJSON形式ではありません。\e[0m"
        exit 1
    fi

    # base64urlエンコード用のヘルパー
    b64url() {
        openssl base64 -e | tr -d '\n' | tr -d '=' | tr '/+' '_-'
    }

    # 1. ヘッダー（HS256固定）
    local header_b64=$(echo -n '{"alg":"HS256","typ":"JWT"}' | b64url)

    # 2. ペイロード
    local payload_b64=$(echo "$INPUT_DATA" | jq -c . | tr -d '\n' | b64url)

    # 3. 署名
    local header_payload="${header_b64}.${payload_b64}"
    local signature_b64=$(echo -n "$header_payload" | openssl dgst -sha256 -hmac "$VJWT_SECRET" -binary | b64url)

    # トークン出力
    echo "${header_payload}.${signature_b64}"
}

# --- デコード（検証）モード ---
do_decode() {
    local jwt=$(echo -n "$INPUT_DATA" | tr -d '[:space:]')

    local header=$(echo -n "$jwt" | cut -d'.' -f1)
    local payload=$(echo -n "$jwt" | cut -d'.' -f2)
    local original_signature=$(echo -n "$jwt" | cut -d'.' -f3)

    decode_payload() {
        local b64_text=$(echo -n "$payload" | tr '_-' '/+')
        local len=$((${#b64_text} % 4))
        if [ $len -eq 2 ]; then b64_text="${b64_text}=="; fi
        if [ $len -eq 3 ]; then b64_text="${b64_text}="; fi
        echo -n "$b64_text" | base64 --decode 2>/dev/null | jq .
    }

    if [ "$INSECURE_MODE" = true ]; then
        echo -e "\e[33m⚠️  警告: 署名検証をスキップしました（検証なし）\e[0m"
        decode_payload
    else
        local header_payload="${header}.${payload}"
        local calculated_signature=$(echo -n "$header_payload" | openssl dgst -sha256 -hmac "$VJWT_SECRET" -binary | base64 | tr -d '=' | tr '/+' '_-')

        if [ "$original_signature" = "$calculated_signature" ]; then
            echo -e "\e[32m✅ 署名一致（改ざんなし）\e[0m"
            decode_payload
        else
            echo -e "\e[31m❌ 署名不一致（改ざんの可能性、または秘密鍵が違います）\e[0m"
            echo "※ 署名を無視して中身を見たい場合は -i オプションを付けてください。"
            exit 1
        fi
    fi
}

# ==========================================
# メイン処理の振り分け
# ==========================================
if [ "$ENCODE_MODE" = true ]; then
    do_encode
else
    do_decode
fi
